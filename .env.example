# Copy this file to .env and fill in the real values. The .env file is
# gitignored — never commit it.
#
# These variables are ONLY needed when you build a release with:
#   npm run release
#
# The app itself uses no environment variables at runtime. Day-to-day
# development with `npm run electron:dev` does not require any of these.

# ---- Apple Developer (for code signing + notarization) ----
# Your Apple ID email (the one tied to your Developer Program account).
APPLE_ID=you@example.com

# An app-specific password from https://account.apple.com/account/manage
# (Sign-In and Security → App-Specific Passwords). NOT your Apple ID
# password. Looks like: abcd-efgh-ijkl-mnop
APPLE_APP_SPECIFIC_PASSWORD=abcd-efgh-ijkl-mnop

# Your 10-character Apple Developer Team ID. Find it at
# https://developer.apple.com/account → Membership Details.
# Also update package.json → build.mac.notarize.teamId to match.
APPLE_TEAM_ID=ABCDE12345

# ---- GitHub (for publishing releases) ----
# A personal access token with `repo` scope, created at
# https://github.com/settings/tokens. electron-builder uploads the signed
# DMG to GitHub Releases using this.
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
