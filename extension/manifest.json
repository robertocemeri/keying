{
  "manifest_version": 3,
  "name": "Keying",
  "version": "0.1.2",
  "description": "Autofill from your local Keying vault. No cloud, no account — credentials live in the Keying app on your Mac.",
  "homepage_url": "https://github.com/robertocemeri/keying",
  "author": "Roberto Cemeri",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "http://127.0.0.1:17321/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Keying",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "keying@cemeri.dev",
      "strict_min_version": "115.0"
    }
  }
}
