{
  "name": "keying",
  "private": true,
  "version": "0.1.4",
  "description": "Keying — a local, encrypted password manager for macOS",
  "main": "dist-electron/main.js",
  "homepage": "https://github.com/robertocemeri/keying",
  "author": {
    "name": "Roberto Cemeri",
    "email": "robertocemeri29@gmail.com"
  },
  "license": "MIT",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "start": "vite",
    "setup:dev-icon": "node scripts/setup-dev-icon.mjs",
    "electron:dev": "npm run setup:dev-icon && concurrently -k \"vite\" \"wait-on tcp:5173 && tsc -p tsconfig.electron.json && cross-env NODE_ENV=development electron .\"",
    "electron:build": "tsc -p tsconfig.electron.json && vite build && electron-builder --mac",
    "extension:zip": "node scripts/build-extension.mjs",
    "promos:build": "node scripts/build-promos.mjs",
    "version:bump": "node scripts/bump-version.mjs",
    "release": "node scripts/bump-version.mjs && dotenv -e .env -- bash -c 'tsc -p tsconfig.electron.json && vite build && electron-builder --mac --publish always'",
    "release:nobump": "dotenv -e .env -- bash -c 'tsc -p tsconfig.electron.json && vite build && electron-builder --mac --publish always'"
  },
  "build": {
    "appId": "com.cemeri.keying",
    "productName": "Keying",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/icon-*.png",
      "build/icon.icns",
      "!**/*.map"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "dmg": {
      "writeUpdateInfo": true
    },
    "publish": {
      "provider": "github",
      "owner": "robertocemeri",
      "repo": "keying",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^11.0.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
